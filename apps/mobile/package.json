    "android:apk": "npm run prebuild:android && node -e \"const fs=require('fs');const p='android/gradle.properties';fs.writeFileSync(p,fs.readFileSync(p,'utf8').replace('newArchEnabled=true','newArchEnabled=false'))\" && cd android && ./gradlew assembleRelease"
